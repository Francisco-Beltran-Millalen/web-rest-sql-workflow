# ============================================================
# PROJECT ARTIFACTS
# Generated by the workflow stages — project-specific, not
# part of the workflow template.
# ============================================================

# Root-level design documents (docs/*.md except workflow-changelog.md)
docs/*.md
!docs/workflow-changelog.md

# Architecture Decision Records
docs/adrs/*.md

# UI assets (views, CSS, SQL, diagrams)
docs/assets/views/*.html
docs/assets/css/*.css
docs/assets/diagrams/*.md
docs/assets/*.sql
docs/assets/templates/

# Imported artifacts (raw imports + adapted files)
imported-artifacts/*
!imported-artifacts/.gitkeep

# ============================================================
# SESSION LOGS
# Conversation transcripts are project-specific and too large
# to include in the template. The workflow-changelog.md
# captures all meaningful changes in human-readable form.
# ============================================================

docs/logs/stage-*.txt
docs/logs/session-*.txt
docs/logs/.auto-export.pid

# ============================================================
# RUNTIME & LOCAL
# ============================================================

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Local Claude Code settings (machine-specific)
.claude/settings.local.json
